<https://euaiact.eu/ontology> a owl:Ontology ;
    rdfs:label "EU AI Act Knowledge Graph Ontology" ;
    dcterms:created "2026-02-11" ;
    dcterms:creator "Masters Research Project" ;
    rdfs:comment "Ontology for the EU AI Act knowledge graph, transformed from Neo4j LLM-extracted graph. Designed for Graph RAG comparison study." .

