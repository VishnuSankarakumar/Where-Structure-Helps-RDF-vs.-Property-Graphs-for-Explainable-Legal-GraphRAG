    euai:chunkOf <https://euaiact.eu/resource/Document/EUAIAct-1-44_pdf> ;
    euai:chunkText "/20, 2020, p. 6. (6) European Parliament resolution of 20 October 2020 with recommendations to the Commission on a framework of ethical aspects  of artificial intelligence, robotics and related technologies, 2020/2012(INL)." ;
    euai:contentOffset 10587 ;
