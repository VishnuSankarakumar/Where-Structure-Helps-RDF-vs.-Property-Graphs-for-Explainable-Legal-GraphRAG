        euai_c:b320180bd38ed7d6d63e75e88bb541cb4e9c4c28,
        euai_c:c2a521d20a0fae1e089651701334b242763c4050,
        euai_c:c6ee3df11c7424391c36e6cde5695745fba69c04,
        euai_c:e30332e60e45958c715b203e0dd24e9200fbbd9a,
        euai_c:e6de5e8e7adcd241f7f24dd723d285ce6ee0321d,
        euai_c:ecc5dcee56a82a19ace13f98d64c8bc52338abae ;
    euai:outsideScopeOf <https://euaiact.eu/resource/Policy/Regulation> ;
    euai:protects <https://euaiact.eu/resource/Right/personal_data> ;
    euai:provides <https://euaiact.eu/resource/LegalConcept/effective_remedies> ;
    euai:pursuesObjective <https://euaiact.eu/resource/Policy/legitimate_public_interest_objectives> ;
    euai:regulatedBy <https://euaiact.eu/resource/Process/identity_checks>,
        <https://euaiact.eu/resource/System/AI_systems>,
        <https://euaiact.eu/resource/System/high-risk_AI_systems> ;
