    euai:position 173 .

euai_c:9670bf7ba17cd78a6aa9793d6b41e9db77fb7b2d a euai:DocumentChunk ;
    euai:chunkOf <https://euaiact.eu/resource/Document/EUAIAct-1-44_pdf> ;
    euai:chunkText " the Union, providers established in third  countries should, by written mandate, appoint an authorised representative established in the Union. This authorised  representative plays a pivotal role in ensuring the compliance of the high-risk AI systems placed on the market or  put into service in the Union by those providers who are not established in the Union and in serving as their contact  person established in the Union. (83) In light of the nature and complexity of the value chain for AI systems and in line with the" ;
    euai:contentOffset 159065 ;
    euai:fileName "EUAIAct-1-44.pdf" ;
    euai:pageNumber 23 ;
    euai:position 324 .

euai_c:9ee36f10a68f5deb2c4bb74354241f4624246e92 a euai:DocumentChunk ;
    euai:chunkOf <https://euaiact.eu/resource/Document/EUAIAct-1-44_pdf> ;
    euai:chunkText " that the persons assigned to  implement the instructions for use and human oversight as set out in this Regulation have the necessary  EN OJ L, 12.7.2024 24/144 ELI: http://data.europa.eu/eli/reg/2024/1689/oj" ;
    euai:contentOffset 168769 ;
    euai:fileName "EUAIAct-1-44.pdf" ;
    euai:pageNumber 24 ;
    euai:position 343 .

euai_c:b48f43de482002e32304dd371d291b0c43990e73 a euai:DocumentChunk ;
    euai:chunkOf <https://euaiact.eu/resource/Document/EUAIAct-1-44_pdf> ;
    euai:chunkText " use of data and amending Regulation (EU) 2017/2394 and Directive (EU) 2020/1828 (Data Act) (OJ L, 2023/2854,  22.12.2023, ELI: http://data.europa.eu/eli/reg/2023/2854/oj)." ;
    euai:contentOffset 253401 ;
    euai:fileName "EUAIAct-1-44.pdf" ;
    euai:pageNumber 36 ;
    euai:position 509 .

euai_c:eb0abd7ea6f496dede37e0c330a1953e03642f8f a euai:DocumentChunk ;
    euai:chunkOf <https://euaiact.eu/resource/Document/EUAIAct-1-44_pdf> ;
    euai:chunkText " this system has the capability to serve a variety of  purposes. A general-purpose AI system can be used directly, or it may be integrated into other AI systems. EN OJ L, 12.7.2024 26/144 ELI: http://data.europa.eu/eli/reg/2024/1689/oj" ;
    euai:contentOffset 182622 ;
    euai:fileName "EUAIAct-1-44.pdf" ;
    euai:pageNumber 26 ;
    euai:position 371 .

euai_c:ff0f2bccf6dba0a5a845747aff0573d555b6cb06 a euai:DocumentChunk ;
    euai:chunkOf <https://euaiact.eu/resource/Document/EUAIAct-1-44_pdf> ;
    euai:chunkText "mining, under certain conditions. Under these rules, rightsholders may choose to reserve their rights over their  works or other subject matter to prevent text and data mining, unless this is done for the purposes of scientific  research. Where the rights to opt out has been expressly reserved in an appropriate manner, providers of  general-purpose AI models need to obtain an authorisation from rightsholders if they want to carry out text and  data mining over such works. (106) Prov" ;
    euai:contentOffset 189930 ;
    euai:fileName "EUAIAct-1-44.pdf" ;
    euai:pageNumber 28 ;
    euai:position 386 .

