    euai:chunkOf <https://euaiact.eu/resource/Document/EUAIAct-1-44_pdf> ;
    euai:chunkText ".europa.eu/eli/reg/2024/1689/oj (16) Directive (EU) 2019/882 of the European Parliament and of the Council of 17 April 2019 on the accessibility requirements for  products and services (OJ L 151, 7.6.2019, p. 70)." ;
    euai:contentOffset 55193 ;
    euai:fileName "EUAIAct-1-44.pdf" ;
