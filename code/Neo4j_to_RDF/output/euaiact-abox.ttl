    euai:chunkOf <https://euaiact.eu/resource/Document/EUAIAct-1-44_pdf> ;
    euai:chunkText " 5.5.2017, p. 176). (23) Directive 2006/42/EC of the European Parliament and of the Council of 17 May 2006 on machinery, and amending Directive  95/16/EC (OJ L 157, 9.6.2006, p. 24)." ;
    euai:contentOffset 83364 ;
    euai:fileName "EUAIAct-1-44.pdf" ;
